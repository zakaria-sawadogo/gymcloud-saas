# ── Base de données ──────────────────────────────────────────
DATABASE_URL="postgresql://gymcloud_app:CHANGE_ME@localhost:5432/gymcloud?schema=public"

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET="CHANGE_ME_ACCESS_SECRET_MIN_32_CHARS"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS"
JWT_REFRESH_EXPIRES_IN="30d"

# ── Redis (cache + files BullMQ) ────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ── Stockage objets (MinIO / S3) ────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="CHANGE_ME"
S3_SECRET_KEY="CHANGE_ME"
S3_BUCKET="gymcloud-files"

# ── Intégrations paiement (clés chiffrées en base — voir ApiCredential) ─
ORANGE_MONEY_ENV="sandbox"
MOOV_MONEY_ENV="sandbox"
WAVE_ENV="sandbox"

# ── SMS / WhatsApp ───────────────────────────────────────────
SMS_PROVIDER="africastalking"
WHATSAPP_BUSINESS_ENV="sandbox"

# ── Application ──────────────────────────────────────────────
PORT="3000"
NODE_ENV="development"
CORS_ORIGINS="http://localhost:3001"
# Si vous prévisualisez le frontend via l'aperçu intégré d'un éditeur de
# code (Cursor, Windsurf...), celui-ci sert parfois la page depuis une
# adresse loopback différente (ex: http://127.94.0.1:3001 au lieu de
# http://localhost:3001) — une origine distincte du point de vue de
# CORS. Dans ce cas, soit ouvrez l'app dans un vrai onglet de navigateur
# (recommandé), soit ajoutez cette origine ici, séparée par une virgule :
# CORS_ORIGINS="http://localhost:3001,http://127.94.0.1:3001"
