# Copier ce fichier en `.env` dans ce même dossier avant `docker compose up`.
# Toutes les valeurs ci-dessous sont des exemples de développement —
# à régénérer avec des secrets forts avant tout déploiement réel.

POSTGRES_PASSWORD=changeme_dev_only
JWT_ACCESS_SECRET=changeme_dev_only_min_32_characters_long
JWT_REFRESH_SECRET=changeme_dev_only_min_32_characters_long
MINIO_ROOT_USER=gymcloud_admin
MINIO_ROOT_PASSWORD=changeme_dev_only

# ── Production uniquement (laisser les valeurs par défaut en local) ──
# Domaine réel où l'API est joignable depuis l'extérieur — utilisé à
# la fois pour CORS (accepter les requêtes du frontend) et pour
# NEXT_PUBLIC_API_URL (le frontend doit savoir où appeler l'API).
# Depuis que la vitrine est intégrée à l'app (§3.2, plus de site
# séparé sur un autre hébergement), un seul domaine suffit ici.
# NEXT_PUBLIC_API_URL est un ARG de build Docker, pas une simple
# variable d'exécution — une modification ici exige de reconstruire
# l'image frontend (`docker compose up -d --build web`), un simple
# `restart` ne suffit pas.
# CORS_ORIGINS="https://gymcloud.sahelsystem.com"
# NEXT_PUBLIC_API_URL="https://gymcloud.sahelsystem.com/api/v1"
