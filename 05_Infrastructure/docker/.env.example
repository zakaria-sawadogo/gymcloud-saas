# Copier ce fichier en `.env` dans ce même dossier avant `docker compose up`.
# Toutes les valeurs ci-dessous sont des exemples de développement —
# à régénérer avec des secrets forts avant tout déploiement réel.

POSTGRES_PASSWORD=changeme_dev_only
JWT_ACCESS_SECRET=changeme_dev_only_min_32_characters_long
JWT_REFRESH_SECRET=changeme_dev_only_min_32_characters_long
MINIO_ROOT_USER=gymcloud_admin
MINIO_ROOT_PASSWORD=changeme_dev_only
